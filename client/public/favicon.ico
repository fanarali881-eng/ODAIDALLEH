        jQuery(document).ready(function($) {
            $('.faq-tab-content .accordion-item:first-child').addClass('active');
            $('.faq-tab-content .accordion-item:first-child .accordion-collapse').addClass('show');
            $('.faq-tab-content .collapse').on('show.bs.collapse', function() {
                $(this).parent().addClass('active');
