        jQuery(document).ready(function($) {
            $(".drop-down-arrow").on("click", function() {
                $("body").toggleClass("menu-overlay");
            });

            // Optional: remove overlay when dropdown closes
            $(document).on("click", function(e) {
                if (!$(e.target).closest(".drop-down-arrow, .dropdown-menu").length) {
                    $("body").removeClass("menu-overlay");
                }
            });
        });


        jQuery(document).ready(function($) {
            var navbar = $(".navbar");
            var offset = navbar.offset().top; // get initial navbar position

            $(window).on("scroll", function() {
                if ($(window).scrollTop() > offset) {
                    navbar.addClass("sticky-nav");
                } else {
                    navbar.removeClass("sticky-nav");
                }
            });
        });

        AOS.init();

         // Handle course category clicks from header navigation
        jQuery(document).ready(function($) {
            // Function to trigger tab activation based on hash
            function triggerTabFromHash() {
                const currentPath = window.location.pathname;
                if (!currentPath.includes('driving-courses')) return;
                
                const hash = window.location.hash.substring(1).toLowerCase();
                if (!hash) return;
                
                // Find the tab button with matching data-target (case-insensitive)
                const tabButtons = document.querySelectorAll('.tablinks');
                let targetButton = null;
                
                tabButtons.forEach(function(button) {
                    const dataTarget = button.getAttribute('data-target');
                    if (dataTarget && dataTarget.toLowerCase() === hash) {
                        targetButton = button;
                    }
                });
                
                if (targetButton) {
                    // Trigger click on the tab button
                    targetButton.click();
                    
                    // Scroll to courses content
                    setTimeout(function() {
                        const coursesContent = document.getElementById('driving-courses-content');
                        if (coursesContent) {
                            coursesContent.scrollIntoView({
                                behavior: 'smooth',
                                block: 'start'
                            });
                        }
                    }, 200);
                }
            }
            
            // Handle clicks on course category links in header
            $('a[href*="driving-courses#"]').on('click', function(e) {
                const href = $(this).attr('href');
                const hashMatch = href.match(/#(.+)$/);
                
                if (hashMatch) {
                    const hash = hashMatch[1].toLowerCase();
                    const currentPath = window.location.pathname;
                    
                    // Check if we're already on the driving-courses page
                    if (currentPath.includes('driving-courses')) {
                        e.preventDefault();
                        
                        // Update URL hash
                        window.location.hash = hash;
                        
                        // Wait a bit for hash to update, then trigger tab click
                        setTimeout(triggerTabFromHash, 50);
                    }
                    // If not on driving-courses page, let normal navigation happen
                }
            });
            
            // Listen for hash changes (for when user is already on the page)
            $(window).on('hashchange', function() {
                const currentPath = window.location.pathname;
                if (currentPath.includes('driving-courses')) {
                    triggerTabFromHash();
                }
            });
        });





