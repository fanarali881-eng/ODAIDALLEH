    <script src="https://www.ddc.sa/themes/ddc/assets/js/custom.js"></script>
    <script>
        var isRTL = $('html').attr('lang') === 'ar';
        jQuery(document).ready(function($) {



            $('.home-slider').on('init', function(event, slick) {
                var i = 1; // first slide
                $('.current_slide').text(('0' + i).slice(-2));
                $('.total_slide').text(('0' + slick.slideCount).slice(-2));
                var progress = (i / slick.slideCount) * 100;
                $('.slider_process').css('width', progress + '%');
            });

            $('.home-slider').on('afterChange', function(event, slick, currentSlide) {
                var i = (currentSlide ? currentSlide : 0) + 1;
                $('.current_slide').text(('0' + i).slice(-2));
                var progress = (i / slick.slideCount) * 100;
                $('.slider_process').css('width', progress + '%');
            });

            $('.home-slider').slick({
                dots: false,
                infinite: true,
                speed: 1000,
                autoplay: true,
                slidesToShow: 1,
                slidesToScroll: 1,
                rtl: isRTL,
                prevArrow: $('.home_slider_left_arrow'),
                nextArrow: $('.home_slider_right_arrow')
            });




            var $slider = $('.licence-type-slider');

            // Move arrows into the about block after Slick creates them
            function moveArrows() {
                var $arrows = $slider.find('.slick-prev, .slick-next');
                if ($arrows.length) {
                    $('.license-type-section .about-inner-top-content').append($arrows);
                }
            }

            // If already initialized (class exists), move immediately; otherwise on init
            if ($slider.hasClass('slick-initialized')) {
                moveArrows();
            } else {
                $slider.on('init', moveArrows);
            }

            // (Re)initialize if not already
            if (!$slider.hasClass('slick-initialized')) {
                $slider.slick({
                    slidesToShow: 4,
                    slidesToScroll: 1,
                    infinite: true,
                    arrows: true,
                    dots: false,
                    autoplay: true,
                    rtl: isRTL,
                    autoplaySpeed: 3000,
                    responsive: [{
                            breakpoint: 1024,
                            settings: {
                                slidesToShow: 3
                            }
                        },
                        {
                            breakpoint: 600,
                            settings: {
                                slidesToShow: 1
                            }
                        }
                    ]
                });
            }


            $('[lang="en"] .logo-carousel-1').slick({
                slidesToShow: 6,
                slidesToScroll: 1,
                autoplay: true,
                autoplaySpeed: 0,
                speed: 4000,
                cssEase: 'linear',
                infinite: true,
                arrows: false,
                dots: false,
                rtl: isRTL,
                pauseOnHover: false,
                pauseOnFocus: false,
                responsive: [{
                        breakpoint: 1024, // tablet & small laptops
                        settings: {
                            slidesToShow: 4
                        }
                    },
                    {
                        breakpoint: 768, // tablets
                        settings: {
                            slidesToShow: 3
                        }
                    },
                    {
                        breakpoint: 480, // mobile
                        settings: {
